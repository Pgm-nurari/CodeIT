##########################
# Universal Git Ignore   #
# For Python + Java Dev  #
#    + Node.js/Express   #
##########################

# ------------------------
# OS / Editor junk
# ------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ------------------------
# Python
# ------------------------
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Django / Flask
*.log
local_settings.py
db.sqlite3*
instance/
.webassets-cache

# Jupyter / IPython
.ipynb_checkpoints
profile_default/
ipython_config.py

# Virtual envs
.env
.envrc
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Type checkers
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
.ruff_cache/

# ------------------------
# Java
# ------------------------
# Compiled class files
*.class

# Log files
*.log

# BlueJ
*.ctxt

# J2ME temp
.mtj.tmp/

# Package files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

