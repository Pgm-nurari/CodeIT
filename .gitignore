pids/
*.pid
*.seed
*.pid.lock

# Build output
dist/
build/
.next/
.nuxt/
out/

# Environment variables
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# Dependency lock (keep one, ignore the others if needed)
